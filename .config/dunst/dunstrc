[global]
    monitor = 0
    follow = mouse

    width = 320
    height = (0, 200)
    origin = top-right
    offset = (10, 50)
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4
    highlight = "#A8C7FF"

    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    frame_width = 1
    frame_color = "#A8C7FF"
    separator_color = frame
    corner_radius = 6

    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = off

    sticky_history = yes
    history_length = 20

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1F2228"
    foreground = "#6B7280"
    frame_color = "#2D3138"
    timeout = 4

[urgency_normal]
    background = "#1F2228"
    foreground = "#E0E1DD"
    frame_color = "#A8C7FF"
    timeout = 6

[urgency_critical]
    background = "#1F2228"
    foreground = "#A8C7FF"
    frame_color = "#FF6B6B"
    timeout = 0
